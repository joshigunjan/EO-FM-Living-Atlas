{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EO-FM Living Atlas catalogue entry",
  "type": "object",
  "required": [
    "id",
    "name",
    "scope",
    "category",
    "downstream_tasks",
    "modelling_paradigm",
    "modelling_paradigm_key"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "input_modality": {
      "type": "string"
    },
    "modality_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "architecture": {
      "type": "string"
    },
    "architecture_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "downstream_tasks": {
      "type": "string"
    },
    "training_scale": {
      "type": "string"
    },
    "openness": {
      "type": "string",
      "enum": [
        "open",
        "partial",
        "closed",
        "unknown"
      ]
    },
    "openness_label": {
      "type": "string"
    },
    "paper_url": {
      "type": "string"
    },
    "code_url": {
      "type": "string"
    },
    "weights_url": {
      "type": "string"
    },
    "project_url": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "modelling_paradigm_key": {
      "type": "string",
      "enum": [
        "transformer_masked",
        "joint_embedding",
        "vision_language",
        "state_space",
        "embedding_field",
        "generative_hybrid"
      ]
    },
    "modelling_paradigm": {
      "type": "string",
      "enum": [
        "Transformer / masked-reconstruction encoder",
        "Joint-embedding / contrastive-predictive encoder",
        "Vision-language / EO MLLM",
        "State-space / sequence model",
        "Embedding product / representation field",
        "Any-to-any generative / hybrid multimodal system"
      ]
    }
  }
}
